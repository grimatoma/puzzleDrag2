{
  "compilerOptions": {
    "checkJs": false,
    "noEmit": true,
    "allowJs": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": false,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "types": ["vite/client"],
    "maxNodeModuleJsDepth": 0
  },
  "include": ["src/**/*.js", "src/**/*.jsx"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.js",
    "**/*.test.jsx"
  ]
}
