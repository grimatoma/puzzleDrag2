; Engine configuration file for the Godot port of puzzleDrag2.
; Stored as plain text — diffable, hand-editable. See docs/godot-migration-plan.html.
;
; Generated/maintained by hand for the migration. Godot 4.6.

config_version=5

[application]

config/name="puzzleDrag2 (Godot)"
config/description="Godot 4 port of the React+Phaser drag-chain puzzle. Mobile-first."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[display]

; Mobile-first portrait window. Stretch keeps the board centred across devices.
window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1

[input_devices]

; Touch-first: treat touch as mouse so the same drag code serves both.
pointing/emulate_mouse_from_touch=true
pointing/emulate_touch_from_mouse=true

[rendering]

; GL Compatibility renderer — broadest mobile + HTML5 support.
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
