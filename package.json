{
  "name": "puzzle-drag",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:docs",
    "build:docs": "node tools/build-docs.mjs",
    "docs:pixel-viewer": "node tools/build-pixel-pipeline-viewer.mjs",
    "lint": "eslint src/ prototype.tsx --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "typecheck:test-files": "node tools/scan-test-tsc.mjs",
    "action-types:list": "node tools/list-action-types.mjs",
    "action-types:emit": "node tools/list-action-types.mjs --emit",
    "action-types:check": "node tools/list-action-types.mjs --check",
    "config:validate": "vitest run src/__tests__/configSchemas.test.ts",
    "pixelgen:serve": "node .claude/skills/sprite-pipeline/scripts/serve_viewer.mjs",
    "pixelgen:build": "node .claude/skills/sprite-pipeline/scripts/build_viewer.mjs",
    "pixelgen:plan": "node .claude/skills/sprite-pipeline/scripts/build_viewer.mjs --plan",
    "pixelgen:show": "node .claude/skills/sprite-pipeline/scripts/pipeline-patch.mjs show",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "ensure:visual-browser": "node tools/ensure-playwright-browser.mjs",
    "pretest:visual": "npm run ensure:visual-browser",
    "test:visual": "playwright test -c playwright.visual.config.js tests/visual/desktop-smoke.spec.ts tests/visual/balance.desktop-smoke.spec.ts tests/visual/story.desktop-smoke.spec.ts --project=desktop",
    "pretest:visual:update": "npm run ensure:visual-browser",
    "test:visual:update": "playwright test -c playwright.visual.config.js tests/visual/desktop-smoke.spec.ts tests/visual/balance.desktop-smoke.spec.ts tests/visual/story.desktop-smoke.spec.ts --project=desktop --update-snapshots",
    "pretest:visual:headed": "npm run ensure:visual-browser",
    "test:visual:headed": "playwright test -c playwright.visual.config.js tests/visual/desktop-smoke.spec.ts --project=desktop --headed",
    "pretest:visual:all": "npm run ensure:visual-browser",
    "test:visual:all": "playwright test -c playwright.visual.config.js tests/visual/visual.spec.ts tests/visual/balance.visual.spec.ts tests/visual/story.visual.spec.ts",
    "pretest:visual:all:update": "npm run ensure:visual-browser",
    "test:visual:all:update": "playwright test -c playwright.visual.config.js tests/visual/visual.spec.ts tests/visual/balance.visual.spec.ts tests/visual/story.visual.spec.ts --update-snapshots",
    "pretest:visual:mobile": "npm run ensure:visual-browser",
    "test:visual:mobile": "playwright test -c playwright.visual.config.js tests/visual/visual.spec.ts --project=iphone-portrait",
    "pretest:visual:mobile:update": "npm run ensure:visual-browser",
    "test:visual:mobile:update": "playwright test -c playwright.visual.config.js tests/visual/visual.spec.ts --project=iphone-portrait --update-snapshots",
    "test:visual:manifest": "node tests/visual/generateManifest.mjs && vitest run src/__tests__/visual-scenarios.test.js"
  },
  "dependencies": {
    "phaser": "^3.87.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.4",
    "postcss": "^8.5.13",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.3.4",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.5"
  }
}
