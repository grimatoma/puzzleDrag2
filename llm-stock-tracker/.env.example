# Copy to .env and fill in real keys to use live providers.
# When these are unset, the app falls back to deterministic mock providers (fully offline).

# LLM provider (used when config.llm.provider === "openai")
OPENAI_API_KEY=

# Market-data provider (used when config.market.provider === "alphavantage")
ALPHAVANTAGE_API_KEY=

# Market-data provider (used when config.market.provider === "finnhub")
FINNHUB_API_KEY=
