node_modules/
dist/
.DS_Store
*.log
test-results/
playwright-report/
playwright/.cache/
coverage/

# Secrets / local agent config — never commit. MCP server configs and env files can
# carry API keys (e.g. PixelLab). Project-scoped agent state and personal overrides also
# stay local. The shared, committed agent config is .claude/settings.json + skills.
.env
.env.*
!.env.example
.mcp.json
.claude.json
.claude/settings.local.json
.claude/.credentials.json

# Repo-root icon-review/ scratch dir — rendered before/after PNGs, contact sheets,
# and the generated manifest. Disposable working area; the committed tracker
# (docs/icon-review.html) now references extracted PNGs under docs/assets/icon-review/
# (which IS tracked — note the leading slash anchors this rule to the repo root only).
/icon-review/

# Godot scratch captures from tools/size_capture.gd & tools/screenshot.gd — disposable
# render artifacts used to verify responsive layout / parity; never committed.
_caps/

# sprite-pipeline review viewer — generated by build_viewer.mjs (data.json + a copy of the
# viewer/ template). A disposable build artifact, NOT source. The source it scans —
# v2/_style-spec.json and v2/sets/** (manifests, keyframes, frames, previews, .tres) — IS
# committed; only the built _viewer/ output is ignored.
godot/assets/tiles/v2/_viewer/
