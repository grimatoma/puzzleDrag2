node_modules/
dist/
.DS_Store
*.log
test-results/
playwright-report/
playwright/.cache/
coverage/

# Secrets / local agent config — never commit. MCP server configs and env files can
# carry API keys (e.g. PixelLab). Project-scoped agent state and personal overrides also
# stay local. The shared, committed agent config is .claude/settings.json + skills.
.env
.env.*
!.env.example
.mcp.json
.claude.json
.claude/settings.local.json
.claude/.credentials.json

# Repo-root icon-review/ scratch dir — rendered before/after PNGs, contact sheets,
# and the generated manifest. Disposable working area; the committed tracker
# (reference/docs/icon-review.html) now references extracted PNGs under
# reference/docs/assets/icon-review/ (which IS tracked — note the leading slash
# anchors this rule to the repo root only).
/icon-review/



# Generated pixel-art export scratch dirs (not part of the repo)
output/
output_128/

# Throwaway seasonal-tile batch runners (durable pipeline = reference/tools/pixellab/{pixellab.mjs,check_pad.py}).
# Rejected candidates + intermediates are archived OUTSIDE the repo at
# <Documents>\aiDev\puzzleDrag2-art-archive\seasonal-tiles\ (kept, never committed).
reference/tools/pixellab/_*

# Seasonal-tile review montages/strips — regenerated by assemble_gifs.py, review-only.
reference/docs/seasonal-tile-system/assets/_review/
/_review/

# graphify local AST cache — regenerated by `graphify update .`. The graph
# artifacts (graph.json ~6.5MB, GRAPH_REPORT.md) are also regenerable, so they
# are untracked too; manifest.json stays committed as a lightweight index.
graphify-out/cache/
graphify-out/graph.json
graphify-out/GRAPH_REPORT.md

# Dev/QA screenshot captures (parity review, layout debug). Regenerable, never
# referenced by source — leading slash anchors this to the repo-root dir only.
/_caps/

# AI playtest harness output — regenerable via `npm run playtest`. The committed
# drift-guarded record is the snapshot in src/__tests__/playtest-harness.test.ts;
# only the README (how to run + what it found) is committed here.
reference/docs/playtest/*
!reference/docs/playtest/README.md

# Design-review workflow scratch script (transient)
scratchpad-review-workflow.mjs
